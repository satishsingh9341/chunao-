{
  "name": "chunao-saathi-backend",
  "version": "1.0.0",
  "description": "Chunao Saathi - Election Education App Backend (Firebase Firestore)",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit",
    "test:ci": "node --experimental-vm-modules node_modules/.bin/jest --coverage --forceExit --ci"
  },
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".js"
    ],
    "transform": {},
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    }
  },
  "dependencies": {
    "@google-cloud/logging": "^10.5.0",
    "@google-cloud/storage": "^7.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
